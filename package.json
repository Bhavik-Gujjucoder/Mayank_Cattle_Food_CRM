{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test:e2e": "playwright test --config=e2e/playwright.config.ts",
        "test:e2e:local": "playwright test --config=e2e/playwright.config.ts --project=local",
        "test:e2e:staging": "playwright test --config=e2e/playwright.config.ts --project=staging",
        "test:e2e:prod": "playwright test --config=e2e/playwright.config.ts --project=prod",
        "test:e2e:install": "playwright install chromium",
        "test:e2e:report": "playwright show-report e2e/playwright-report"
    },
    "devDependencies": {
        "@playwright/test": "^1.52.0",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.7"
    }
}
